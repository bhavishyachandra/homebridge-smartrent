{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "ES2022"],
    "rootDir": "src",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "declaration": false,
    "declarationMap": false,
    "removeComments": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.spec.ts"]
}
